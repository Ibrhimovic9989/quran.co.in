# quran.co.in API — environment
# Copy to .env for local development.

# Server
PORT=3001
NODE_ENV=development

# CORS: comma-separated allowed web origins
WEB_ORIGIN=http://localhost:3000

# Database (Supabase Postgres with pgvector)
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/postgres

# External Quran API override (optional)
# QURAN_COM_API_URL=

# --- Phase 2 (auth) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# COOKIE_DOMAIN=.quran.co.in

# --- AI: free-tier fallback chain (tried in order; set whichever you have) ---
# 1) NVIDIA NIM — free at https://build.nvidia.com (key looks like nvapi-...)
#    Rate limits are PER MODEL, so every model adds free capacity. The chain is
#    a curated quality-first head PLUS every other chat-capable model on the
#    live roster, auto-discovered from /v1/models (refreshed every 6h;
#    embedding/reward/safety/vision/code/reasoning/tiny models filtered out).
# NVIDIA_API_KEY=
# NVIDIA_AUTO_DISCOVER=true            # set false for curated head only
# NVIDIA_CHAT_MODELS=                  # CSV override — replaces head AND discovery
#
# 2) OpenRouter — free models at https://openrouter.ai (key looks like sk-or-...)
#    Free quota is account-wide; defaults to a curated :free model list.
#    Later: load credit and set OPENROUTER_CHAT_MODELS to a paid model first.
# OPENROUTER_API_KEY=
# OPENROUTER_CHAT_MODELS=meta-llama/llama-3.3-70b-instruct:free,deepseek/deepseek-chat:free
#
# Embedding space: 'nvidia' (default when NVIDIA_API_KEY set) uses the FREE
# llama-nemotron-embed-1b-v2 corpus in verse/tafsir_embeddings_v2 (2048-dim,
# built by apps/api/scripts/re-embed-nvidia.mjs). 'azure' switches back to the
# legacy text-embedding-3-small tables.
# EMBEDDINGS_PROVIDER=nvidia
#
# 3) Azure OpenAI (legacy, optional last-resort for chat + the v1 embedding
#    space). Without any embedding provider, search degrades to Postgres
#    full-text automatically.
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
# AZURE_OPENAI_CHAT_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=
# AZURE_OPENAI_CHAT_API_VERSION=

# quran.co.in API — environment
# Copy to .env for local development.

# Server
PORT=3001
NODE_ENV=development

# CORS: comma-separated allowed web origins
WEB_ORIGIN=http://localhost:3000

# Database (Supabase Postgres with pgvector)
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/postgres

# External Quran API override (optional)
# QURAN_COM_API_URL=

# --- Phase 2 (auth) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# COOKIE_DOMAIN=.quran.co.in

# --- AI: free-tier fallback chain (tried in order; set whichever you have) ---
# 1) NVIDIA NIM — free at https://build.nvidia.com (key looks like nvapi-...)
#    Per-model rate limits, so the fallback model adds extra headroom.
# NVIDIA_API_KEY=
# NVIDIA_CHAT_MODEL=meta/llama-3.3-70b-instruct
# NVIDIA_CHAT_MODEL_FALLBACK=meta/llama-3.1-8b-instruct
#
# 2) OpenRouter — free models at https://openrouter.ai (key looks like sk-or-...)
#    Later: load credit and switch OPENROUTER_CHAT_MODEL to a paid model.
# OPENROUTER_API_KEY=
# OPENROUTER_CHAT_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_CHAT_MODEL_FALLBACK=
#
# 3) Azure OpenAI (legacy, optional last-resort for chat; REQUIRED for vector
#    semantic search until the corpus is re-embedded with a free model —
#    the pgvector corpus is text-embedding-3-small/1536-dim).
#    Without it, search degrades to Postgres full-text automatically.
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
# AZURE_OPENAI_CHAT_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=
# AZURE_OPENAI_CHAT_API_VERSION=

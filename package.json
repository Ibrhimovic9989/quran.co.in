{
  "name": "quran-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w web",
    "build:web": "npm run build -w web",
    "dev:api": "npm run start:dev -w api",
    "build:api": "npm run build -w api",
    "db:generate": "npm run generate -w @quran/database",
    "db:migrate": "npm run migrate -w @quran/database",
    "db:studio": "npm run studio -w @quran/database"
  }
}

{
  "name": "quran.co.in",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:index": "dotenv -e .env.local -- tsx scripts/add-indexes.ts",
    "sync:quran": "dotenv -e .env.local -- tsx scripts/sync-quran.ts",
    "update:translations": "dotenv -e .env.local -- tsx scripts/update-translations.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.0",
    "@prisma/client": "^6.1.0",
    "clsx": "^2.1.1",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^2.6.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.0",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0"
  }
}
